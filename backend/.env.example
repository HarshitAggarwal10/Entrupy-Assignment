# Backend Environment Configuration
# Copy this to .env and update values

# Database Configuration
# SQLite (default for dev)
DATABASE_URL=sqlite:///./test.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/price_monitor

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Notification Configuration
# Comma-separated webhook URLs
WEBHOOK_URLS=

# Logging
LOG_LEVEL=INFO
