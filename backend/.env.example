# Backend Environment Configuration
# Copy this to .env and update values

# Database Configuration
# SQLite (default for dev)
DATABASE_URL=sqlite:///./test.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/price_monitor

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# JWT Secret (change in production)
SECRET_KEY=your-super-secret-jwt-key-change-in-production-2024

# Notifications — Webhook URLs (comma-separated, optional)
# Leave empty to disable webhook delivery. EventLog handler always runs.
# Example: WEBHOOK_URLS=https://your-server.com/webhook,https://other.com/hook
WEBHOOK_URLS=

# Logging
LOG_LEVEL=INFO
